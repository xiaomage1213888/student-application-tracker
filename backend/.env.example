# 服务配置
PORT=3000
NODE_ENV=development

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 数据库配置
# SQLite (开发环境)
DB_DIALECT=sqlite
DB_STORAGE=./data/database.sqlite

# MySQL (生产环境)
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=student_tracker
# DB_USER=root
# DB_PASSWORD=yourpassword

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
